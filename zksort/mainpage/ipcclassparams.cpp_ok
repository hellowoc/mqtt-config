void ipcclassparams::sClassModeChanged(int index)
{
    struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classMode[m_curPage*CONST_MAX_MODEL_PER_PAGE+index]
            = m_pModeCombox[m_curPage*CONST_MAX_MODEL_PER_PAGE+index]->currentIndex();

//    updateView();
}
void ipcclassparams::showPage(bool bshow)
{
    basewidget::showPage(bshow);
    if(bshow){
        struGsh.isInIpcClassPage = 1;
        struGsh.nLayer = 0;
        struGsh.nView = 0;
        struGsh.nMatGroup = 0;

        updateViewButtonVisible();
        updateViewBtnState();
        updateGroupWidgetState();

        getCurrentViewIpcIndex();

        for(int i = 0; i < struCnfg.nIpcCount; i++)
        {
            struCnfp.ipcModelClassCount[i] = struIpcShare.struIpcModelClass[i].classCount;
        }

        m_curPage = 0;
        m_totalPage = (struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]%CONST_MAX_MODEL_PER_PAGE==0)
                ?struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]/CONST_MAX_MODEL_PER_PAGE:struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]/CONST_MAX_MODEL_PER_PAGE+1;

        updateView();

        basewidget::showPage(bshow);
    }
    else
    {
        struGsh.isInIpcClassPage = 0;
    }
}

void ipcclassparams::receiveMsg(int msg1, int msg2, int msg3)
{
    if(msg1 == MSG_DATA_CHANGED){
        if (msg2 <= MAX_IPC_MODEL_CLASS*2){
            if(msg2 < MAX_IPC_MODEL_CLASS)
            {
                struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classSens[msg2] = m_sensValue[msg2];
#if 0
                switch(struCnfg.nIpcCameraClassSameMode)
                {
                case 0:
                    break;
                case 1:
                    for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
                    {
                        struCnfp.struCameraIpcClassParams[m_curLayer][i].classSens[msg2] = m_sensValue[msg2];
                    }
                    break;
                case 2:
                    struCnfp.struCameraIpcClassParams[m_curLayer][struGsh.nView+1].classSens[msg2] = m_sensValue[msg2];
//                    for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
//                    {
//                        struCnfp.struCameraIpcClassParams[m_curLayer][i].classSens[msg2] = struCnfp.struCameraIpcClassParams[m_curLayer][i/2].classSens[msg2];
//                    }
                    break;
                }
#endif
            }
            else
            {
                struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classThreshold[msg2-MAX_IPC_MODEL_CLASS] = m_ThresholdValue[msg2-MAX_IPC_MODEL_CLASS];
#if 0
                switch(struCnfg.nIpcCameraClassSameMode)
                {
                case 0:
                    break;
                case 1:
                    for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
                    {
                        struCnfp.struCameraIpcClassParams[m_curLayer][i].classThreshold[msg2-MAX_IPC_MODEL_CLASS] = m_ThresholdValue[msg2-MAX_IPC_MODEL_CLASS];
                    }
                    break;
                case 2:
                    struCnfp.struCameraIpcClassParams[m_curLayer][struGsh.nView+1].classThreshold[msg2] = m_ThresholdValue[msg2-MAX_IPC_MODEL_CLASS];
//                    for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
//                    {
//                        struCnfp.struCameraIpcClassParams[m_curLayer][i].classThreshold[msg2-MAX_IPC_MODEL_CLASS] = struCnfp.struCameraIpcClassParams[m_curLayer][i/2].classSens[msg2-MAX_IPC_MODEL_CLASS];
//                    }
                    break;
                }
#endif
            }
//            updateView();
        }
        else if(msg2 == 100)
        {
            if(0 > struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]])
            {
                for(int i = 0; i < struCnfg.nIpcCount; i++)
                {
                    struCnfp.ipcModelClassCount[i] = 0;
                }
            }
            if (MAX_IPC_MODEL_CLASS < struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]] )
            {
                for(int i = 0; i < struCnfg.nIpcCount; i++)
                {
                    struCnfp.ipcModelClassCount[i] = MAX_IPC_MODEL_CLASS;
                }
            }
            m_totalPage = (struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]%CONST_MAX_MODEL_PER_PAGE==0)
                ? struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]/CONST_MAX_MODEL_PER_PAGE:struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]/CONST_MAX_MODEL_PER_PAGE+1;
            if(m_curPage >= m_totalPage)
            {
                m_curPage = m_totalPage-1;
            }
            if (m_totalPage == 0) m_curPage = 0;
            updateView();
        }
        else if(msg2 == 101)
        {
//            updateView();
        }
        else if(msg2 == 102)
        {
//            updateView();
        }
    }
}

void ipcclassparams::OnViewChange(int view)
{
//    ui->widget->update();
    updateView();
}

void ipcclassparams::OnChuteChange()
{
    updateView();
}

void ipcclassparams::OnGroupChange(int groupIndex)
{
    updateView();
}

void ipcclassparams::OnLayerChange()
{
//    ui->widget->update();
    updateView();
}

void ipcclassparams::retranslateUiWidget()
{
    ui->applyBtn->setText(g_myLan().ids_apply);
//    ui->checkBox_bias->setText(g_myLan().camera_signal_bias_enable);
    ui->labelLengthLimit->setText(g_myLan().ids_lowlimit);
    ui->advBtn->setText(g_myLan().advance);
    for(int i = 0;i < CONST_MAX_MODEL_PER_PAGE; i++){
        m_pBoxClassLable[i]->setText(g_myLan().ids_lowlimit);
        m_pTickModeClass[i]->setText(g_myLan().ipc_heavyBlow);
        m_pFixedClass[i]->setText(g_myLan().maximum); //最值
        m_pModeLabel[i]->setText(g_myLan().ids_model);
    }
}

void ipcclassparams::updateView()
{
#if 0
    for(int i = 0; i < MAX_VIEW; i++)
    {
        m_viewBtn[i]->hide();
    }

    for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
    {
        if(struCnfg.struLayerInfo[0].nViewIsUsed[i] == 1)
        {
            m_viewBtn[i]->show();
        }
    }

    switch(struCnfg.nIpcCameraClassSameMode)
    {
    case 0:
        for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
        {
            if(struCnfg.struLayerInfo[0].nViewIsUsed[i] == 1)
            {
                m_viewBtn[i]->setEnabled(true);
            }
        }
        break;
    case 1:
        m_viewBtn[0]->setEnabled(true);
        m_viewBtn[1]->setEnabled(false);
        m_viewBtn[2]->setEnabled(false);
        m_viewBtn[3]->setEnabled(false);
        break;
    case 2:
        m_viewBtn[0]->setEnabled(true);
        m_viewBtn[1]->setEnabled(false);
        m_viewBtn[2]->setEnabled(true);
        m_viewBtn[3]->setEnabled(false);
        break;
    }

    for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
    {
        m_viewBtn[i]->setChecked(false);
    }
    m_viewBtn[struGsh.nView]->setChecked(true);
#endif
    ui->labelIpcNum->hide();

    ui->lastPageBtn->setFixedWidth(60);
    ui->nextPageBtn->setFixedWidth(60);

    ui->comboBoxIpcSelect->setMinimumSize(150, 40);
    ui->comboBoxIpcSelect->clear();
    QStringList ipcTypeList;

    for(int i = 0; i < struCnfg.nIpcCount; i++)
    {
        QString ipcType = QString("IPC%1").arg(i+1);
        ipcTypeList.append(ipcType);
    }
    ui->comboBoxIpcSelect->addItems(ipcTypeList);
    ui->comboBoxIpcSelect->setCurrentIndex(m_curIpcIndex);

    ui->comboBoxIpcSelect->hide();

    ui->classCountWidget->setParams(this,0, MAX_IPC_MODEL_CLASS,100,&struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]);
    ui->classCountWidget->setTitle(g_myLan().ipc_classCount);
    ui->classCountWidget->setValue(struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]);
    ui->classCountWidget->setVisible(struGsh.debugMode);
//    ui->classCountWidget->setEnabled(struGsh.bRunMode > RUNMODE_USER);

    ui->lineEditLengthLimit->setText(QString::number(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].lengthLimit));
    ui->lineEditLengthLimit->setMinMax(this, 0, 10000000, 101,&struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].lengthLimit);

    for(int i = 0;i < CONST_MAX_MODEL_PER_PAGE;i++){
        m_pClassSensEdit[i]->setVisible(false);
        m_pClassEnable[i]->setVisible(false);
        m_pClassThresholdEdit[i]->setVisible(false);
        m_nameClassEdit[i]->setVisible(false);
        m_pBoxClassLable[i]->setVisible(false);
        m_pBoxClassEdit[i]->setVisible(false);
        m_pTickModeClass[i]->setVisible(false);
        m_pFixedClass[i]->setVisible(false);
        m_pModeLabel[i]->setVisible(false);
        m_pModeCombox[i]->setVisible(false);


        if(i < (struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]-m_curPage*CONST_MAX_MODEL_PER_PAGE)){
//        if(i < MAX_IPC_MODEL_CLASS){
            m_pClassEnable[i]->setVisible(true);
            m_pClassEnable[i]->setChecked(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classEnable[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);
            m_sensValue[m_curPage*CONST_MAX_MODEL_PER_PAGE+i] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classSens[m_curPage*CONST_MAX_MODEL_PER_PAGE+i];
            m_pClassSensEdit[i]->setVisible(true);
//            m_pClassSensEdit[i]->setFixedWidth(280);
            m_pClassSensEdit[i]->setParams(this,0,100,m_curPage*CONST_MAX_MODEL_PER_PAGE+i,&m_sensValue[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);
            m_pClassSensEdit[i]->setTitle(QString::number(m_curPage*CONST_MAX_MODEL_PER_PAGE+i+1));
//            m_pClassSensEdit[i]->setTitle(QString("%1").arg(struIpcShare.struIpcModelClass[m_curIpcIndex].className[i]));
            m_pClassSensEdit[i]->setValue(m_sensValue[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);

            m_ThresholdValue[m_curPage*CONST_MAX_MODEL_PER_PAGE+i] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classThreshold[m_curPage*CONST_MAX_MODEL_PER_PAGE+i];
//            qDebug()<<"m_ThresholdValue"<<i<<m_ThresholdValue[i];
            m_pClassThresholdEdit[i]->setVisible(true);
//            m_pClassThresholdEdit[i]->setFixedWidth(280);
            m_pClassThresholdEdit[i]->setParams(this,0,100, MAX_IPC_MODEL_CLASS+m_curPage*CONST_MAX_MODEL_PER_PAGE+i,&m_ThresholdValue[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);
            m_pClassThresholdEdit[i]->setTitle("");
            m_pClassThresholdEdit[i]->setValue(m_ThresholdValue[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);

            m_nameClassEdit[i]->setVisible(true);
            m_nameClassEdit[i]->setFixedWidth(150);
            m_nameClassEdit[i]->setText(QString("%1").arg(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].className[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]));

            //高级参数
            m_pBoxClassLable[i]->setVisible(true);
            m_pBoxClassEdit[i]->setVisible(true);
            m_pBoxClassEdit[i]->setText(QString::number(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classLabelBox[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]));
            if (struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classMode[m_curPage*CONST_MAX_MODEL_PER_PAGE+i] == 1)
                labelBoxValueLimit = 24;
            else
                labelBoxValueLimit = 65535;
            m_pBoxClassEdit[i]->setMinMax(this, 0, labelBoxValueLimit, 102,&struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classLabelBox[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);

            m_pTickModeClass[i]->setVisible(true);
            m_pTickModeClass[i]->setChecked(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classTickMode[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);

            m_pFixedClass[i]->setVisible(true);
            m_pFixedClass[i]->setChecked(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classFixMode[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);

            m_pModeLabel[i]->setVisible(true);
            m_pModeLabel[i]->setText(g_myLan().ids_model);
            m_pModeCombox[i]->setVisible(true);
            m_pModeCombox[i]->setCurrentIndex(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classMode[m_curPage*CONST_MAX_MODEL_PER_PAGE+i]);
        }
    }
}

void ipcclassparams::on_comboBoxIpcSelect_activated(int index)
{
    m_curIpcIndex = index;
    qDebug("m_curIpcIndex is %d", m_curIpcIndex);

    updateView();
//    struCnfg.struIpcCameraParams[m_curLayer][struGsh.nView][cameraIndex].ipcType = m_pIpcTypeCmx[cameraIndex]->currentIndex();
}

void ipcclassparams::on_applyBtn_clicked()
{
    for(int i = 0;i < struCnfp.ipcModelClassCount[m_curViewIpcIndex[struGsh.nView]]-m_curPage*CONST_MAX_MODEL_PER_PAGE; i++){
        if(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classMode[m_curPage*CONST_MAX_MODEL_PER_PAGE+i] == 1){
            if(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classLabelBox[m_curPage*CONST_MAX_MODEL_PER_PAGE+i] > 24){
                g_infoWidget().setLabelText("模式2:框最大不能超过24");
                g_infoWidget().showSecs();
                return;
            }
        }
    }

    g_infoWidget().setLabelText(g_myLan().ids_apply);
    g_infoWidget().delayShow();

    switch(struCnfg.nIpcCameraClassSameMode)
    {
    case 0:
        break;
    case 1: //整机相同， == 一次前主
        for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
        {
            for(int j = 0; j < struCnfg.struLayerInfo[0].stuViewInfo[j].nIdentifyGroupTotal; j++)
            {
                for(int m = 0; m < MAX_IPC_MODEL_CLASS; m++)
                {
                    struCnfp.struCameraIpcClassGroupParams[m_curLayer][i][j].classEnable[m] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0][0].classEnable[m];
                    struCnfp.struCameraIpcClassGroupParams[m_curLayer][i][j].classSens[m] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0][0].classSens[m];
                    struCnfp.struCameraIpcClassGroupParams[m_curLayer][i][j].classThreshold[m] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0][0].classThreshold[m];

                    struCnfp.struCameraIpcClassGroupParams[m_curLayer][i][j].classLabelBox[m] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0][0].classLabelBox[m];
                    struCnfp.struCameraIpcClassGroupParams[m_curLayer][i][j].classTickMode[m] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0][0].classTickMode[m];
                    struCnfp.struCameraIpcClassGroupParams[m_curLayer][i][j].classFixMode[m] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0][0].classFixMode[m];
                    struCnfp.struCameraIpcClassGroupParams[m_curLayer][i][j].classMode[m] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0][0].classMode[m];
                }
            }
        }
        break;
//    case 2: //层内相同
//        for(int j = 0; j < MAX_IPC_MODEL_CLASS; j++)
//        {
//            struCnfp.struCameraIpcClassGroupParams[m_curLayer][1].classEnable[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0].classEnable[j];
//            struCnfp.struCameraIpcClassGroupParams[m_curLayer][1].classSens[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0].classSens[j];
//            struCnfp.struCameraIpcClassGroupParams[m_curLayer][1].classThreshold[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0].classThreshold[j];

//            struCnfp.struCameraIpcClassGroupParams[m_curLayer][1].classLabelBox[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0].classLabelBox[j];
//            struCnfp.struCameraIpcClassGroupParams[m_curLayer][1].classTickMode[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0].classTickMode[j];
//            struCnfp.struCameraIpcClassGroupParams[m_curLayer][1].classFixMode[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][0].classFixMode[j];
//        }
//        if(struCnfg.struLayerInfo[0].nViewChainTotal == 4)
//        {
//            for(int j = 0; j < MAX_IPC_MODEL_CLASS; j++)
//            {
//                struCnfp.struCameraIpcClassGroupParams[m_curLayer][3].classEnable[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][2].classEnable[j];
//                struCnfp.struCameraIpcClassGroupParams[m_curLayer][3].classSens[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][2].classSens[j];
//                struCnfp.struCameraIpcClassGroupParams[m_curLayer][3].classThreshold[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][2].classThreshold[j];

//                struCnfp.struCameraIpcClassGroupParams[m_curLayer][3].classLabelBox[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][2].classLabelBox[j];
//                struCnfp.struCameraIpcClassGroupParams[m_curLayer][3].classTickMode[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][2].classTickMode[j];
//                struCnfp.struCameraIpcClassGroupParams[m_curLayer][3].classFixMode[j] = struCnfp.struCameraIpcClassGroupParams[m_curLayer][2].classFixMode[j];}
//        }
//        break;
    }
    for(int i = 0; i < struCnfg.nIpcCount; i++)
    {
        myFlow.configIpcClassParams(i);
    }
    g_infoWidget().hide();
}

void ipcclassparams::on_lastPageBtn_clicked()
{
    if(m_curPage > 0)
    {
        m_curPage--;
    }
    updateView();
}

void ipcclassparams::on_nextPageBtn_clicked()
{
    if(m_curPage < m_totalPage-1)
    {
        m_curPage++;
    }
    updateView();
}


void ipcclassparams::on_advBtn_clicked()
{
    g_MainManager().ShowWidget(SM_IPC_CLASS_ADV_PARAMS_WIDGET);
}
