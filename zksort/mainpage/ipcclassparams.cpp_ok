ipcclassparams::~ipcclassparams()
{
    delete ui;
}

void ipcclassparams::getCurrentViewIpcIndex()
{
    switch(struCnfg.nIpcCount)
    {
    case 1:
        for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
        {
            m_curViewIpcIndex[i] = 0;
        }
        break;
    case 2:
        for(int i = 0; i < struCnfg.struLayerInfo[0].nViewChainTotal; i++)
        {
            int tmpIpcId[MAX_VIEW];
            tmpIpcId[i] = 0;

            if(struCnfg.struIpcCameraParams[0][i][0].ipcType > 0)
            {
                tmpIpcId[i] = struCnfg.struIpcCameraParams[0][i][0].ipcType-1;
            }
            m_curViewIpcIndex[i] = tmpIpcId[i];
        }
        break;
    default:
        break;
    }
}

void ipcclassparams::sClassEnableSlots(int index)
{
    struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classEnable[m_curPage*CONST_MAX_MODEL_PER_PAGE+index]
            = !struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classEnable[m_curPage*CONST_MAX_MODEL_PER_PAGE+index];

//    updateView();
}

void ipcclassparams::sClass1NameChanged(int index)
{
    memset(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].className[m_curPage*CONST_MAX_MODEL_PER_PAGE+index],0,
            sizeof(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].className[m_curPage*CONST_MAX_MODEL_PER_PAGE+index]));

    QString name = m_nameClassEdit[index]->text();
    QByteArray namearr = name.toUtf8();
    const char *strName = namearr.data();
    memcpy(struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].className[m_curPage*CONST_MAX_MODEL_PER_PAGE+index],strName,strlen(strName));
}

void ipcclassparams::sClassLabelBoxChanged(int index)
{
    struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classEnable[m_curPage*CONST_MAX_MODEL_PER_PAGE+index]
            = !struCnfp.struCameraIpcClassGroupParams[m_curLayer][struGsh.nView][struGsh.nMatGroup].classEnable[m_curPage*CONST_MAX_MODEL_PER_PAGE+index];

