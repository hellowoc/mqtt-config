NewMainPage QLabel{
	color:#666666;
	font-size:30px;
	min-width:140px;
	max-width:140px;
}


NewMainPage QPushButton{
	background-color:rgba(0,0,0,0);
}
NewMainPage QPushButton:pressed{
	background-color:rgba(0,0,0,0);
}

NewMainPage QPushButton:checked{
	background-color:rgba(0,0,0,0);
}
NewMainPage QPushButton#runBtn{
	text-align:center;
	padding: 0px -20px 0px 20px;
	font:bold 34px; 
	min-width:300px;
	min-height:133px;
	max-width:300px;
	max-height:133px;
	border-radius:4px;
	color:#666666;
	border-image:url(:/white/run_nm.png);
}
NewMainPage QPushButton#runBtn:pressed{
	color:white;
	border-image:url(:/white/run_press.png);
}
NewMainPage QPushButton#runBtn:checked{
	color:white;
	border-image:url(:/white/stop_press.png);
}

QPushButton#wheelBtn{
	font:bold 34px; 
	min-width:266px;
	min-height:120px;
	max-width:266px;
	max-height:120px;
	border-radius:4px;
	color:#666666;
