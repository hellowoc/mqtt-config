}
QPushButton#wheelBtn:checked{
	color:#666666;
	border-image:url(:/white/wheel_press.png);
}

QPushButton#shutdownBtn{
	text-align:center;
	padding: 0px -30px 0px 30px;
	font:bold 34px; 
	min-width:300px;
	min-height:133px;
	max-width:300px;
	max-height:133px;
	color:#666666;
	border-image:url(:/white/shutdown_nm.png);
