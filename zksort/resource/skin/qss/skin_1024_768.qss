QComboBox {
	font:30px "Arial";
   color:rgb(55,57,66);	
	border: 1px solid #c9c9c9;
     border-radius: 5px;
     padding: 1px 15px 1px 3px;
	 subcontrol-origin: padding;
     subcontrol-position: top right;
     width: 15px;
	 min-height:50px;
	 max-height:50px;
}
 QComboBox::drop-down {
     subcontrol-origin: border;
     subcontrol-position: right;
	 font:10px;
     width: 15px;
     border-left-style: solid;
	 image:url(:/white/combobox_arrow_down.png)
 }
 QComboBox::down-arrow {
     image: url(:/white/combobox_arrow_nm.png);
     margin-left:0px;
 }
 QComboBox::down-arrow:hover {
     image:url(:/white/combobox_arrow_on.png);
 }
 QComboBox::down-arrow:pressed {
     image:url(:/white/combobox_arrow_down.png);
 }
 QComboBox::down-arrow:disabled {
     image:url(:/white/combobox_arrow_ul.png);
	}
     
 QComboBox QAbstractItem {
	 min-height:42px;
 }
QCheckBox {
     spacing: 8px;
	 color:#666666;
	 font-size:28px;
 }

 QCheckBox::indicator {
     width: 48px;
     height: 48px;
 }
QCheckBox::indicator:unchecked{image: url(:/white/unchecked.png);}
QCheckBox::indicator:checked{image: url(:/white/check.png);}


QRadioButton{
	font-size:20px;
	color:#333333;
	background-color:rgba(0,0,0,0);
}

QRadioButton::indicator:checked{image:url(:/white/radio_check.png);background-color:rgba(0,0,0,0);}
QRadioButton::indicator:unchecked{image:url(:white/radio_unchecked.png);background-color:rgba(0,0,0,0);}

QScrollBar::vertical {background:#eeeeee; border:0px solid grey;min-width:40px;margin:40px 0px 40px 0px; }
QScrollBar::handle:vertical { border: 1px solid grey; border-radius:0px; min-height: 40px; min-width:40px; background:#a2d2f9;} 
QScrollBar::add-line:vertical { height: 40px; subcontrol-origin:margin; } 
QScrollBar::sub-line:vertical { height: 40px; subcontrol-origin:margin; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: none;border:0,0,0,0; }

QScrollBar::horizontal {background:#eeeeee; border:0px solid grey;min-height:40px;margin:0px 40px 0px 40px; }
QScrollBar::handle:horizontal { border: 1px solid grey; border-radius:0px; min-width: 40px; min-height:40px; background:#a2d2f9;} 
QScrollBar::add-line:horizontal { width: 40px; subcontrol-origin:margin; subcontrol-position: right;} 
QScrollBar::sub-line:horizontal { width: 40px; subcontrol-origin:margin; subcontrol-position: left;}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal { background: none;border:0,0,0,0; }
QScrollArea { border:0,0,0,0;}

