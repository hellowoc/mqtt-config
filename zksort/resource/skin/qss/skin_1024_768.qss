*{
	font-family:Arial;
}
QLabel{
	font-size:25px;
	color:#007ffc;
}
QLabel#titleLbl{
	min-width:200px;
	font:26px;
	color:white;
}

QPushButton#conveyorBtn{
	min-width:230px;
	min-height:80px;
	max-width:230px;
	max-height:80px;
	border-radius:22px;
	margin-left:-1px;
	margin-bottom:-1px;
	border-image:url(:/white/conveyor_normal.png);
}

QPushButton#conveyorBtn:pressed{
	border-image:url(:/white/conveyor_down.png);
}
QLabel#alarmLbl{
	min-width:40px;
	min-height:40px;
	max-width:40px;
	max-height:40px;
	border-image:url(:/white/baojing.png);
}

QHeaderView::section {
	background-color:#2583f3;
	min-height:32px;
	max-height:32px;
	font:bold 20px "Arial"; 
	color:white;
	border: 1px;
}
QTableWidget
{
	font:bold 20px; 
	color:rgb(140,140,140);
}

QDialog{
	border-image:url(:/white/dialog_bg.png);
}
MySetDateTime{
	border-image:url(:/white/dateset_bg.png);
}
MySetDateTime QPushButton{
	border-image:url(:/white/ok_nm.png);
}

MySetDateTime QPushButton:pressed{
	border-image:url(:/white/ok_press.png);
}
QLabel#netLbl{
	min-width:40px;
	min-height:40px;
	max-width:40px;
	max-height:40px;
	border-image:url(:/white/disconnect.png);
}
QLabel#label_group{
	font-size:26px;
}	
QLineEdit{
	min-width:100px;
	max-width:250px;
	min-height:44px;
	max-height:44px;
	font-size:30px;
	qproperty-alignment:AlignHCenter;
	border:2px solid #e2e2e2;
	background-color:white;
}
QPushButton{
	min-width:120px;
	max-width:120px;
	min-height:50px;
	max-height:50px;
	font-size:20px;
	border-radius:2px;
	color:#333333;
	background-color:#addfff;
	outline:none;
}
QPushButton:pressed{
	color:white;
	background-color:#2583f3;
}
QPushButton:checked{
	color:white;
	background-color:#2583f3;
}
QPushButton:disabled{
	background-color:rgb(216,216,216);
}
QPushButton#timeLabel{
	font:20px;
	color:white;
	max-width:120px;
	min-width:120px;
	background-color:rgba(0,0,0,0);
}
QPushButton#timeLabel:hover{
	border-left:1px solid grey;
	border-right:1px solid grey;
}
QPushButton#okBtn{
	border-image:url(:/white/ok_nm.png);
}
QPushButton#okBtn:hover{
	border-image:url(:/white/ok_press.png);
}
QPushButton#okBtn:pressed{
	border-image:url(:/white/ok_press.png);
}
QPushButton#cancelBtn{
	border-image:url(:/white/ok_nm.png);
}
QPushButton#cancelBtn:hover{
	border-image:url(:/white/ok_press.png);
}
QPushButton#cancelBtn:pressed{
	border-image:url(:/white/ok_press.png);
}
QPushButton#reCheck{
	min-width:160px;
	min-height:50px;
	color:#2583f3;
	border-image:url(:/white/recheck_nm.png);
}
QPushButton#reCheck:hover{
	color:white;
	border-image:url(:/white/recheck_press.png);
}
QPushButton#reCheck:pressed{
	color:white;
	border-image:url(:/white/recheck_press.png);
}
QPushButton#enterMainPageBtn{
	min-width:160px;
	min-height:50px;
	color:#2583f3;
	border-image:url(:/white/enter_nm.png);
}
QPushButton#enterMainPageBtn:hover{
	color:white;
	border-image:url(:/white/enter_press.png);
}
QPushButton#enterMainPageBtn:pressed{
	color:white;
	border-image:url(:/white/enter_press.png);
}

QPushButton#simulateBtn{
	min-width:120px;
	min-height:50px;
	padding:0px -20px 0 20px;
	color:#2583f3;
	border-image:url(:/white/simulate_nm.png);
}
QPushButton#simulateBtn:pressed{
	color:white;
	border-image:url(:/white/simulate_press.png);
}
QPushButton#simulateBtn:checked{
	color:white;
	border-image:url(:/white/simulate_press.png);
}
QPushButton#simulateBtn:disabled{
	color:gray;
	border-image:url(:/white/simulate_nm.png);
}
QPushButton#vavletest{
        min-width:120px;
        min-height:50px;
        color:#2583f3;
        background-color:white;
}
QPushButton#vavletest:pressed{
        color:white;
        background-color:rgb(251,153,18);
}
QPushButton#vavletest:disabled{
        color:gray;
}

QPushButton#ipcClassBtn{
	min-width:120px;
	min-height:50px;
	color:#2583f3;
	background-color:white;
}
QPushButton#ipcClassBtn:pressed{
	color:white;
	background-color:rgb(251,153,18);
}
QPushButton#ipcClassBtn:disabled{
	color:gray;
}

QPushButton#moreBtn{
	min-width:120px;
	min-height:50px;
	color:#2583f3;
	background-color:white;
}
QPushButton#moreBtn:pressed{
	color:white;
	background-color:rgb(251,153,18);
}
QPushButton#moreBtn:disabled{
	color:gray;
}

QPushButton#moreBtn_2{
	min-width:120px;
	min-height:50px;
	color:#2583f3;
	background-color:white;
}
QPushButton#moreBtn_2:pressed{
	color:white;
	background-color:rgb(251,153,18);
}
QPushButton#moreBtn_2:disabled{
	color:gray;
