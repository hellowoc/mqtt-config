QGroupBox{
	color:#666666;
	font:bold;
	border:none;
	margin:0px;
	font-size:15px;
	border:2px solid #cccccc;
 }
QGroupBox::title{
	 font-size:31px;
	 color:#007ffc;
	 margin-top:-2px;
 }
QGroupBox::indicator:unchecked{image: url(:/white/unchecked.png);}
QGroupBox::indicator:checked{image: url(:/white/check.png);}

