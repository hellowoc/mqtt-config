QListWidget{
    font:15px;
	border:1px solid blue;
	color:gray;
}
QListWidget::Item{
	padding-top:2px;
	padding-bottom:3px;
}
QListWidget::Item:hover{
	background-color:skyblue;
}
QListWidget::Item:selected{
	background:lightgray;
	color:red;
}
QListWidget::Item:selected:!active{
	border-width:0px;
	background:lightgreen;
}

QTabWidget::pane {
	border: 1px solid gray;
	 border-style: outset;
	 background-color: rgb(132, 171, 208);
	 background: transparent;
 }
QTabWidget::tab-bar{
	alignment:left;
} 
QTabBar::tab{ 
	background-color:#addfff;
	border-bottom-color: rgb(48, 104, 151); 
	border: 1px solid rgb(193, 218, 248);
	min-width:164px; 
	min-height:35px;
	font:23px;
	} 
QTabBar::tab:hover{  
	background-color:#2583f3; 
 } 
QTabBar::tab:selected{  
	border-color: white;   
	background-color:#2583f3;  
	color:white;   
	border-top: 1px solid yellow; 
}
QTabBar::tab:disabled{
	width: 0;
	background-color:transparent;
	border-width: 0px; 
	color: transparent;
}

