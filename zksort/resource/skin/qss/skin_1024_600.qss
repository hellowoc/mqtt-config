QComboBox {
	font:23px "arial";
   color:rgb(55,57,66);	
	border: 1px solid #c9c9c9;
     border-radius: 3px;
     padding: 2px 2px 2px 2px;
	 subcontrol-origin: padding;
     subcontrol-position: top right;
     width: 11px;
	 min-height:39px;
	 max-height:39px;
}
 QComboBox::drop-down {
     subcontrol-origin: border;
     subcontrol-position: right;
	 font:7px;
     width: 11px;
     border-left-style: solid;
	 image:url(:/white/combobox_arrow_down.png)
 }
 QComboBox::down-arrow {
     image: url(:/white/combobox_arrow_nm.png);
     margin-left:0px;
 }
 QComboBox::down-arrow:hover {
     image:url(:/white/combobox_arrow_on.png);
 }
 QComboBox::down-arrow:pressed {
     image:url(:/white/combobox_arrow_down.png);
 }
 QComboBox::down-arrow:disabled {
     image:url(:/white/combobox_arrow_ul.png);
	}
     
 QComboBox QAbstractItem {
	 min-height:32px;
 }
QCheckBox {
         spacing: 6px;
	 color:#666666;
	 font-size:21px;
 }

 QCheckBox::indicator {
     width: 30px;
     height: 30px;
 }
QCheckBox::indicator:unchecked{image: url(:/white/unchecked.png);}
QCheckBox::indicator:checked{image: url(:/white/check.png);}


QRadioButton{
	font-size:15px;
	color:#333333;
	background-color:rgba(0,0,0,0);
}

QRadioButton::indicator:checked{image:url(:/white/radio_check.png);background-color:rgba(0,0,0,0);}
QRadioButton::indicator:unchecked{image:url(:white/radio_unchecked.png);background-color:rgba(0,0,0,0);}

QScrollBar::vertical {background:#eeeeee; border:0px solid grey;min-width:31px;margin:31px 0px 31px 0px; }
QScrollBar::handle:vertical { border: 1px solid grey; border-radius:0px; min-height: 31px; min-width:31px; background:#a2d2f9;} 
QScrollBar::add-line:vertical { height: 31px; subcontrol-origin:margin; } 
QScrollBar::sub-line:vertical { height: 31px; subcontrol-origin:margin; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: none;border:0,0,0,0; }

QScrollBar::horizontal {background:#eeeeee; border:0px solid grey;min-height:31px;margin:0px 31px 0px 31px; }
QScrollBar::handle:horizontal { border: 1px solid grey; border-radius:0px; min-width: 31px; min-height:31px; background:#a2d2f9;} 
QScrollBar::add-line:horizontal { width: 31px; subcontrol-origin:margin; subcontrol-position: right;} 
QScrollBar::sub-line:horizontal { width: 31px; subcontrol-origin:margin; subcontrol-position: left;}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal { background: none;border:0,0,0,0; }
QScrollArea { border:0,0,0,0;}

